{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "linden",
  "name": "Mesosphere Documentation",
  "colors": {
    "primary": "#FF7B9C",
    "light": "#FF7B9C",
    "dark": "#FF7B9C"
  },
  "fonts": {
    "heading": {
      "family": "TTNormsPro-ExtraBold",
      "format": "woff2",
      "source": "/public/font/TTNormsPro-ExtraBold.woff2"
    },
    "body": {
      "family": "TTNormsPro-ExtraBold",
      "format": "woff2",
      "source": "/public/font/TTNormsPro-ExtraBold.woff2"
    }
  },
  "styling": {
    "codeblocks": "system"
  },
  "background": {
    "color": {
      "light": "#F5F0F6",
      "dark": "#161925"
    }
  },
  "search": {
    "prompt": "Search the documentation..."
  },
  "favicon": "/public/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": " ",
        "groups": [
          {
            "group": "Welcome to Mesosphere",
            "pages": ["/docs/home"]
          },
          {
            "group": "Get up and running",
            "pages": [
              {
                "group": "Tutorial",
                "icon": "books",
                "root": "/docs/tutorial/chatapp",
                "expanded": false,
                "pages": ["/docs/tutorial/chatapp"]
              },
              {
                "group": "Frameworks",
                "icon": "gear",
                "expanded": false,
                "root": "/docs/framework/quickstart",
                "pages": [
                  "/docs/framework/react",
                  "/docs/framework/react-native",
                  "/docs/framework/nodejs",
                  "/docs/framework/nextjs",
                  "/docs/framework/remix",
                  "/docs/framework/svelte",
                  "/docs/framework/tanstack",
                  "/docs/framework/vue",
                  "/docs/framework/nuxt",
                  "/docs/framework/bun",
                  "/docs/framework/scripttag"
                ]
              },
              "/docs/self-hosting",
              {
                "group": "CLI",
                "icon": "keyboard",
                "root": "/docs/cli/quickstart",
                "pages": ["/docs/cli/local"]
              }
            ]
          },
          {
            "group": "Features",
            "pages": [
              "/docs/realtime",
              {
                "group": "Functions",
                "icon": "code",
                "root": "/docs/functions/quickstart",
                "expanded": false,
                "pages": [
                  "/docs/functions/write",
                  "/docs/functions/read",
                  "/docs/functions/closefunctions",
                  "/docs/functions/sideactions",
                  "/docs/functions/debugging",
                  "/docs/functions/type"
                ]
              },
              {
                "group": "File Storage",
                "icon": "file",
                "root": "/docs/filestorage/quickstart",
                "expanded": false,
                "pages": [
                  "/docs/filestorage/upload",
                  "/docs/filestorage/delete",
                  "/docs/filestorage/sideactions",
                  "/docs/filestorage/metadata"
                ]
              },
              {
                "group": "Authentication",
                "icon": "key",
                "root": "/docs/authentication/quickstart",
                "expanded": false,
                "pages": [
                  "/docs/authentication/clerk",
                  "/docs/authentication/workosauthkit",
                  "/docs/authentication/auth0",
                  "/docs/authentication/betterauth",
                  "/docs/authentication/functions",
                  "/docs/authentication/database",
                  "/docs/authentication/debugging"
                ]
              },
              {
                "group": "Database",
                "icon": "database",
                "root": "/docs/database/quickstart",
                "expanded": false,
                "pages": [
                  "/docs/database/writing",
                  "/docs/database/reading",
                  "/docs/database/documentid",
                  "/docs/database/type",
                  "/docs/database/systemtable"
                ]
              },
              {
                "group": "Scheduling",
                "icon": "timer",
                "root": "/docs/schedule/quickstart",
                "expanded": false,
                "pages": ["/docs/schedule/cron", "/docs/schedule/scheduler"]
              },
              {
                "group": "Vector Embeddings",
                "icon": "magnifying-glass",
                "root": "/docs/vector/quickstart",
                "expanded": false,
                "pages": [
                  {
                    "group": "Python",
                    "icon": "python",
                    "expanded": false,
                    "pages": [
                      {
                        "group": "Examples",
                        "icon": "pencil",
                        "root": "/docs/vector/python/examples/quickstart",
                        "expanded": false,
                        "pages": [
                          "/docs/vector/python/examples/provider",
                          "/docs/vector/python/examples/add",
                          "/docs/vector/python/examples/delete",
                          "/docs/vector/python/examples/query"
                        ]
                      },
                      {
                        "group": "Integration",
                        "icon": "handshake",
                        "root": "/docs/vector/python/integration/quickstart",
                        "expanded": false,
                        "pages": ["/docs/vector/python/integration/quickstart"]
                      }
                    ]
                  },
                  {
                    "group": "TypeScript",
                    "icon": "js",
                    "expanded": false,
                    "pages": [
                      {
                        "group": "Examples",
                        "icon": "pencil",
                        "root": "/docs/vector/ts/examples/quickstart",
                        "expanded": false,
                        "pages": [
                          "/docs/vector/ts/examples/provider",
                          "/docs/vector/ts/examples/add",
                          "/docs/vector/ts/examples/delete",
                          "/docs/vector/ts/examples/query"
                        ]
                      }
                    ]
                  },
                  {
                    "group": "Rust",
                    "icon": "rust",
                    "expanded": false,
                    "pages": [
                      {
                        "group": "Examples",
                        "icon": "pencil",
                        "root": "/docs/vector/rust/examples/quickstart",
                        "expanded": false,
                        "pages": [
                          "/docs/vector/rust/examples/provider",
                          "/docs/vector/rust/examples/add",
                          "/docs/vector/rust/examples/delete",
                          "/docs/vector/rust/examples/query"
                        ]
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "group": "Mesosphere Utilities",
            "pages": [
              "/docs/apiendpoint",
              "/docs/benchmark",
              "/docs/cligeneration",
              "/docs/ratelimit",
              "/docs/testing",
              "/docs/runtime",
              "/docs/production"
            ]
          },
          {
            "group": "Client Libraries",
            "pages": [
              {
                "group": "React",
                "icon": "react",
                "expanded": false,
                "pages": [
                  "/docs/client/react/react",
                  "/docs/client/react/react-native"
                ]
              },
              {
                "group": "JavaScript",
                "icon": "js",
                "root": "/docs/client/javascript/quickstart",
                "expanded": false,
                "pages": [
                  "/docs/client/javascript/node",
                  "/docs/client/javascript/bun",
                  "/docs/client/javascript/scripttag"
                ]
              },
              {
                "group": "Next.js",
                "icon": "/public/sidebar/nextjs.png",
                "expanded": false,
                "pages": [
                  "/docs/client/nextjs/approuter",
                  "/docs/client/nextjs/pagerouter"
                ]
              },
              {
                "group": "Tanstack Start",
                "icon": "/public/sidebar/tanstackstart.png",
                "expanded": false,
                "pages": [
                  {
                    "group": "Tanstack Start",
                    "expanded": false,
                    "root": "/docs/client/tanstack/tanstack-start/quickstart",
                    "pages": [
                      "/docs/client/tanstack/tanstack-start/usewithauth"
                    ]
                  },
                  "/docs/client/tanstack/tanstackquery"
                ]
              },
              "/docs/client/svelte",
              "/docs/client/vue",
              "/docs/client/nuxt",
              "/docs/client/python",
              "/docs/client/rust"
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/public/light.svg",
    "dark": "/public/dark.svg"
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://mesosphere.ahen-studio.com/dashboard"
    },
    "links": [
      {
        "icon": "github",
        "label": " ",
        "href": "https://github.com/ahen-studio/mesosphere-backend"
      }
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/ahen-studio/mesosphere-backend"
    }
  }
}
