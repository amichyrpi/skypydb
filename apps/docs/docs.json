{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Mesosphere Documentation",
  "colors": {
    "primary": "#5438DC",
    "light": "#5438DC",
    "dark": "#5438DC"
  },
  "fonts": {
    "heading": {
      "family": "GT-America-Standard-Bold",
      "format": "woff2",
      "source": "/public/font/GT-America-Standard-Bold.woff2"
    },
    "body": {
      "family": "GT-America-Standard-Bold",
      "format": "woff2",
      "source": "/public/font/GT-America-Standard-Bold.woff2"
    }
  },
  "styling": {
    "codeblocks": "system"
