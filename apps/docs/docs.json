{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "linden",
  "name": "Mesosphere Documentation",
  "colors": {
    "primary": "#E85912",
    "light": "#C653E0",
    "dark": "#C653E0"
  },
  "fonts": {
    "heading": {
      "family": "TTNormsPro-ExtraBold",
      "format": "woff2",
      "source": "/public/font/TTNormsPro-ExtraBold.woff2"
    },
    "body": {
      "family": "TTNormsPro-ExtraBold",
      "format": "woff2",
      "source": "/public/font/TTNormsPro-ExtraBold.woff2"
    }
  },
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "codeblocks": "system"
  },
  "background": {
    "color": {
      "light": "#F1F1F1",
      "dark": "#111111"
    }
  },
  "search": {
    "prompt": "Search the documentation..."
  },
  "favicon": "/public/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": " ",
        "groups": [
          {
            "group": "Welcome to Mesosphere",
            "pages": ["/docs/home"]
          },
          {
            "group": "Get up and running",
            "pages": [
              {
                "group": "Tutorial",
                "icon": "book-marked",
                "root": "/docs/tutorial/chatapp",
                "expanded": false,
                "pages": ["/docs/tutorial/chatapp"]
              },
              {
                "group": "Frameworks",
                "icon": "tool-case",
                "expanded": false,
                "root": "/docs/framework/quickstart",
                "pages": [
                  "/docs/framework/react",
                  "/docs/framework/react-native",
                  "/docs/framework/nodejs",
                  "/docs/framework/nextjs",
                  "/docs/framework/remix",
                  "/docs/framework/svelte",
                  "/docs/framework/tanstack",
                  "/docs/framework/vue",
                  "/docs/framework/nuxt",
                  "/docs/framework/bun",
                  "/docs/framework/scripttag"
                ]
              },
              {
                "group": "CLI",
                "icon": "keyboard",
                "root": "/docs/cli/quickstart",
                "pages": ["/docs/cli/local"]
              }
            ]
          },
          {
            "group": "Features",
            "pages": [
              "/docs/realtime",
              {
                "group": "Functions",
                "icon": "code",
                "root": "/docs/functions/quickstart",
                "expanded": false,
                "pages": [
                  "/docs/functions/write",
                  "/docs/functions/read",
                  "/docs/functions/closefunctions",
                  "/docs/functions/sideactions",
                  "/docs/functions/debugging",
                  "/docs/functions/type"
                ]
              },
              {
                "group": "File Storage",
                "icon": "file",
                "root": "/docs/filestorage/quickstart",
                "expanded": false,
                "pages": [
                  "/docs/filestorage/upload",
                  "/docs/filestorage/delete",
                  "/docs/filestorage/sideactions",
                  "/docs/filestorage/metadata"
                ]
              },
              {
                "group": "Authentication",
                "icon": "key",
                "root": "/docs/authentication/quickstart",
                "expanded": false,
                "pages": [
                  "/docs/authentication/clerk",
                  "/docs/authentication/workosauthkit",
                  "/docs/authentication/auth0",
                  "/docs/authentication/betterauth",
                  "/docs/authentication/customjwtprovider",
                  "/docs/authentication/customoidcprovider",
                  "/docs/authentication/functions",
                  "/docs/authentication/database",
                  "/docs/authentication/debugging"
                ]
              },
              {
                "group": "Database",
                "icon": "database",
                "root": "/docs/database/quickstart",
                "expanded": false,
                "pages": [
                  "/docs/database/writing",
                  "/docs/database/reading",
                  "/docs/database/documentids",
                  "/docs/database/type",
                  "/docs/database/systemtable",
                  "/docs/database/schemas",
                  "/docs/database/backuprestore"
                ]
              },
              {
                "group": "Scheduling",
                "icon": "timer",
                "root": "/docs/schedule/quickstart",
                "expanded": false,
                "pages": ["/docs/schedule/cron", "/docs/schedule/scheduler"]
              },
              {
                "group": "Vector Embeddings",
                "icon": "vector-square",
                "root": "/docs/vector/quickstart",
                "expanded": false,
                "pages": [
                  "/docs/vector/search",
                  "/docs/vector/adding",
                  "/docs/vector/provider",
                  "/docs/vector/query",
                  "/docs/vector/delete",
                  "/docs/vector/integration"
                ]
              }
            ]
          },
          {
            "group": "Utilities",
            "pages": [
              {
                "group": "AI Agents",
                "icon": "bot",
                "root": "/docs/utilities/aiagents/quickstart",
                "expanded": false,
                "pages": [
                  "/docs/utilities/aiagents/claudeai",
                  "/docs/utilities/aiagents/codexai",
                  "/docs/utilities/aiagents/cursorai"
                ]
              },
              "/docs/utilities/benchmark",
              "/docs/utilities/codegeneration",
              {
                "group": "Production",
                "icon": "box",
                "root": "/docs/utilities/production/quickstart",
                "expanded": false,
                "pages": [
                  "/docs/utilities/production/deploying",
                  "/docs/utilities/production/development",
                  "/docs/utilities/production/ratelimit",
                  "/docs/utilities/production/regions",
                  "/docs/utilities/production/getintouch"
                ]
              },
              "/docs/utilities/selfhosting",
              "/docs/utilities/runtime",
              "/docs/utilities/testing"
            ]
          },
          {
            "group": "Client Libraries",
            "pages": [
              {
                "group": "React",
                "icon": "react",
                "expanded": false,
                "pages": [
                  "/docs/client/react/react",
                  "/docs/client/react/react-native"
                ]
              },
              {
                "group": "JavaScript",
                "icon": "js",
                "root": "/docs/client/javascript/quickstart",
                "expanded": false,
                "pages": [
                  "/docs/client/javascript/node",
                  "/docs/client/javascript/bun",
                  "/docs/client/javascript/scripttag"
                ]
              },
              {
                "group": "Next.js",
                "icon": "/public/sidebar/nextjs.png",
                "expanded": false,
                "pages": [
                  "/docs/client/nextjs/approuter",
                  "/docs/client/nextjs/pagerouter"
                ]
              },
              {
                "group": "Tanstack Start",
                "icon": "/public/sidebar/tanstackstart.png",
                "expanded": false,
                "pages": [
                  {
                    "group": "Tanstack Start",
                    "expanded": false,
                    "root": "/docs/client/tanstack/tanstack-start/quickstart",
                    "pages": [
                      "/docs/client/tanstack/tanstack-start/usewithauth"
                    ]
                  },
                  "/docs/client/tanstack/tanstackquery"
                ]
              },
              "/docs/client/svelte",
              "/docs/client/vue",
              "/docs/client/nuxt",
              "/docs/client/python",
              "/docs/client/rust"
            ]
          },
          {
            "group": "Reference",
            "pages": [
              {
                "group": "API Reference",
                "icon": "send-horizontal",
                "root": "/docs/reference/apireference/quickstart",
                "expanded": false,
                "pages": []
              },
              "/docs/reference/openai",
              "/docs/reference/bestpractices"
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/public/light.svg",
    "dark": "/public/dark.svg"
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://mesosphere.ahen-studio.com/dashboard"
    },
    "links": [
      {
        "icon": "github",
        "label": " ",
        "href": "https://github.com/ahen-studio/mesosphere-backend"
      }
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/ahen-studio/mesosphere-backend"
    }
  }
}
